<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- Hive Metastore lưu metadata (table schemas, partition info) vào PostgreSQL -->
  <!-- Mặc định Hive dùng Derby (embedded DB) — không support concurrent access -->
  <!-- PostgreSQL: stable, concurrent-safe, persistent qua container restart -->
  <property>
    <name>javax.jdo.option.ConnectionURL</name>
    <value>jdbc:postgresql://hive-metastore-db:5432/metastore</value>
  </property>
  <property>
    <name>javax.jdo.option.ConnectionDriverName</name>
    <value>org.postgresql.Driver</value>
  </property>
  <property>
    <name>javax.jdo.option.ConnectionUserName</name>
    <value>hive</value>
  </property>
  <property>
    <name>javax.jdo.option.ConnectionPassword</name>
    <value>hive</value>
  </property>

  <!-- Tự tạo schema nếu chưa có (lần đầu khởi động) -->
  <property>
    <name>datanucleus.autoCreateSchema</name>
    <value>true</value>
  </property>
  <property>
    <name>datanucleus.fixedDatastore</name>
    <value>false</value>
  </property>

  <!-- Địa chỉ Thrift server của Metastore — Spark và Trino connect vào đây -->
  <property>
    <name>hive.metastore.uris</name>
    <value>thrift://hive-metastore:9083</value>
  </property>

  <!-- Warehouse dir trên HDFS — nơi Hive tạo MANAGED tables -->
  <!-- EXTERNAL tables (cách mình dùng) tự specify LOCATION riêng -->
  <property>
    <name>hive.metastore.warehouse.dir</name>
    <value>hdfs://namenode:9000/user/hive/warehouse</value>
  </property>

  <!-- Tắt stats collection tự động — tốn thời gian, không cần trong dev -->
  <property>
    <name>hive.stats.autogather</name>
    <value>false</value>
  </property>

  <!-- Cho phép dynamic partition insert mà không cần khai báo partition values trước -->
  <property>
    <name>hive.exec.dynamic.partition</name>
    <value>true</value>
  </property>
  <property>
    <name>hive.exec.dynamic.partition.mode</name>
    <value>nonstrict</value>
  </property>
</configuration>
